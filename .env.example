# Required — from setup_aws.sh output
COMMAND_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/claude-bridge-commands
RESULTS_TABLE=claude-bridge-results
AWS_REGION=us-east-1

# Optional — proactive Alexa speech via Notify Me (https://www.notifymyecho.com)
# Sign up, enable the "Notify Me" skill on your Alexa, get the access code
NOTIFY_ME_ACCESS_CODE=

# Optional — max seconds to wait for Claude to finish a command
CLAUDE_TIMEOUT=300
